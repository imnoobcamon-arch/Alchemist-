# ─── Single analysis pass ────────────────────────────────────────────────────

def run_once() -> None:
    """Fetch data, run strategy, publish result."""
    logger.info("=" * 55)
    logger.info(f"  🤖  ICT Bot — {config.PAIR_DISPLAY}  |  {config.DATA_SOURCE}")
    logger.info("=" * 55)

    status = get_session_status()
    log_session_info(status)

    if status.is_weekend:
        print("\n📅 Weekend — Forex market is closed. No analysis.\n")
        return

    logger.info("📥 Fetching price data …")
    data = fetch_all_timeframes()

    if not data:
        logger.error("No data fetched — check your internet connection or DATA_SOURCE config")
        return

    logger.info("🧠 Running ICT strategy engine …")
    setup = analyse(data)

    publish(setup)


# ─── Live loop ────────────────────────────────────────────────────────────────

def run_loop(interval_minutes: int = 5) -> None:
    """Run analysis repeatedly every `interval_minutes` minutes."""
    print(f"\n🔁  Live mode — analysing every {interval_minutes} min (Ctrl+C to stop)\n")
    session_setup_count = {}   # track setups per session to enforce MAX_SETUPS_PER_SESSION

    while True:
        try:
            status       = get_session_status()
            session_key  = status.current_session or "off"

            count = session_setup_count.get(session_key, 0)
            if count >= config.MAX_SETUPS_PER_SESSION:
                logger.info(
                    f"🛑 Max setups ({config.MAX_SETUPS_PER_SESSION}) reached "
                    f"for {session_key} session — waiting"
                )
            else:
                data  = fetch_all_timeframes()
                setup = analyse(data) if data else None

                if setup:
                    publish(setup)
                    session_setup_count[session_key] = count + 1
                else:
                    logger.info("No setup this cycle")

        except KeyboardInterrupt:
            print("\n⛔ Stopped by user.")
            break
        except Exception as e:
            logger.error(f"Loop error: {e}", exc_info=True)

        logger.info(f"⏳ Sleeping {interval_minutes} min …\n")
        time.sleep(interval_minutes * 60)


# ─── Backtest ─────────────────────────────────────────────────────────────────

def run_backtest() -> None:
    from backtest.backtester import run_backtest as _bt, print_report
    report = _bt(window_size=200, step_size=24, max_trades=50)
    print_report(report)


# ─── CLI ─────────────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        description="ICT Forex Analysis Bot — EURUSD",
        formatter_class=argparse.RawTextHelpFormatter
    )
    parser.add_argument(
        "--loop", action="store_true",
        help="Run in live loop mode (analyse every 5 minutes)"
    )
    parser.add_argument(
        "--interval", type=int, default=5,
        help="Loop interval in minutes (default: 5)"
    )
    parser.add_argument(
        "--backtest", action="store_true",
        help="Run walk-forward backtest"
    )
    parser.add_argument(
        "--demo", action="store_true",
        help="Print a demo signal (no live data required)"
    )

    args = parser.parse_args()

    if args.demo:
        run_demo()
    elif args.backtest:
        run_backtest()
    elif args.loop:
        run_loop(interval_minutes=args.interval)
    else:
        run_once()


if __name__ == "__main__":
    main()
